@ class:   thing
@ extends: model

static table = 'things'

static canView => true
static canChange => true
static canDelete => true

static schema => arr(
	id: field(type: 'number', title: 'ID'),
	name: field(type: 'text', title: 'Name'),
	secret: field(type: 'text', title: 'Secret'),
	tags: field(type: 'many', obj: 'tag', table: 'thing_tags', localKey: 'thing', foreignKey: 'tag'),
)
