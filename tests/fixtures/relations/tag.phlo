@ class:   tag
@ extends: model

static table = 'tags'
static idColumn = 'code'

view: $this->name

static schema => arr(
	code: field(type: 'text', title: 'Code'),
	name: field(type: 'text', title: 'Name'),
)

# A string (non-'id') primary key, to prove field_many resolves the foreign key via idColumn().
static prepareTable {
	$db = static::DB()
	$db->query('CREATE TABLE IF NOT EXISTS tags (code TEXT PRIMARY KEY, name TEXT)')
	$db->query('DELETE FROM tags')
	$db->query('CREATE TABLE IF NOT EXISTS thing_tags (thing INTEGER, tag TEXT)')
	$db->query('DELETE FROM thing_tags')
	$db->query('INSERT INTO tags (code, name) VALUES (?, ?)', 'red', 'Red')
	$db->query('INSERT INTO tags (code, name) VALUES (?, ?)', 'blue', 'Blue')
	$db->query('INSERT INTO thing_tags (thing, tag) VALUES (1, ?)', 'red')
	$db->query('INSERT INTO thing_tags (thing, tag) VALUES (2, ?)', 'blue')
}
