@ class:   tag
@ extends: model

static table = 'tags'

static schema => arr(
	id: field(type: 'number', title: 'ID'),
	name: field(type: 'text', title: 'Name'),
)

static prepareTable {
	$db = static::DB()
	$db->query('CREATE TABLE IF NOT EXISTS tags (id INTEGER PRIMARY KEY, name TEXT)')
	$db->query('DELETE FROM tags')
	$db->query('CREATE TABLE IF NOT EXISTS thing_tags (thing INTEGER, tag INTEGER)')
	$db->query('DELETE FROM thing_tags')
	$db->query('INSERT INTO tags (id, name) VALUES (5, ?)', 'red')
	$db->query('INSERT INTO tags (id, name) VALUES (6, ?)', 'blue')
	$db->query('INSERT INTO thing_tags (thing, tag) VALUES (1, 5)')
	$db->query('INSERT INTO thing_tags (thing, tag) VALUES (2, 6)')
}
