@ summary: BI test probe. Subclasses CMS_dashboard_bi to expose its protected buildQuery, so the
@          BI query builder can be attacked directly: it must reject unknown columns/operators and
@          bind every value as a parameter (no LLM text in the SQL), defeating UNION-style injection.
@ extends:  CMS_dashboard_bi

method probeBuild($model, $res) => $this->buildQuery($model, $res)

static throws($fn):bool {
	try {
		$fn()
		return false
	} catch (\Throwable $e){
		return true
	}
}

static sqliCases {
	thing::prepareTable()
	$bi = phlo('biprobe')
	return [
		'validRows' => count($bi->probeBuild('thing', ['filters' => [['column' => 'name', 'op' => '=', 'value' => 'alice']]])),
		'injectRows' => count($bi->probeBuild('thing', ['filters' => [['column' => 'name', 'op' => '=', 'value' => "alice' OR '1'='1"]]])),
		'unionRows' => count($bi->probeBuild('thing', ['filters' => [['column' => 'name', 'op' => '=', 'value' => "x' UNION SELECT id, secret, name FROM things --"]]])),
		'allRows' => count($bi->probeBuild('thing', ['filters' => []])),
		'unknownColumn' => static::throws(fn() => $bi->probeBuild('thing', ['filters' => [['column' => 'secret; DROP TABLE things', 'op' => '=', 'value' => 'x']]])),
		'unknownOperator' => static::throws(fn() => $bi->probeBuild('thing', ['filters' => [['column' => 'name', 'op' => 'union', 'value' => 'x']]])),
		'badOrderIgnored' => count($bi->probeBuild('thing', ['filters' => [], 'order' => ['column' => 'name); DROP TABLE things --', 'dir' => 'asc']])),
	]
}

static authzHooks => [
	'thingView' => thing::canView(),
	'lockedView' => locked::canView(),
	'thingChange' => thing::canChange(),
	'lockedChange' => locked::canChange(),
	'thingDelete' => thing::canDelete(),
	'lockedDelete' => locked::canDelete(),
]
