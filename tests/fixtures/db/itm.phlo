@ summary: ORM relation test: child item belonging to a list (the child side of
@          the getChildren relation exercised by lst).
@ extends: model

static table = 'items'
static columns = 'id,list_id,label'

static prepareTable {
	static::DB()->query('CREATE TABLE IF NOT EXISTS items (id '.app::autoId(static::DB()).', list_id INTEGER, label TEXT)')
	static::DB()->query('DELETE FROM items')
}
