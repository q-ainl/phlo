@ summary: ORM test model with a non-default idColumn, to exercise create()
@          reloading the new record by its custom primary key rather than 'id'.
@ extends: model

static table = 'codes'
static idColumn = 'slug'
static columns = 'slug,label'

static prepareTable {
	static::DB()->query('CREATE TABLE IF NOT EXISTS codes (slug '.app::textId(static::DB()).', label TEXT)')
	static::DB()->query('DELETE FROM codes')
}

static runTests {
	static::prepareTable()
	$out = []
	$created = static::create(slug: 'abc', label: 'first')
	$out['create'] = (bool)($created && $created->slug === 'abc' && $created->label === 'first')
	$out['reload'] = (static::record(slug: 'abc')->label ?? null) === 'first'
	$out['columns'] = ($created->objData['slug'] ?? null) === 'abc' && ($created->objData['label'] ?? null) === 'first'
	$newObj = new code(slug: 'xyz', label: 'v1')
	$savedNew = $newObj->objSave()
	$out['saveNew'] = ($savedNew->slug ?? null) === 'xyz' && ($savedNew->label ?? null) === 'v1'
	$savedNew->label = 'v2'
	$savedNew->objSave()
	$out['saveUpdate'] = (static::record(slug: 'xyz')->label ?? null) === 'v2'
	return $out
}
