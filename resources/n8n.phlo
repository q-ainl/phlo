@ version:  1.0
@ summary:  Call n8n webhook endpoint
@ package:  network
@ frontend: false
@ backend:  true
@ requires: HTTP creds:n8n
@ tags:     n8n webhook http automation

function n8n($webhook, ?array $data = null, $test = false) => HTTP(%creds->n8n->server.'webhook'.($test ? '-test' : '').'/'.$webhook, POST: $data)
