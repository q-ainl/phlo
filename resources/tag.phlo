@ summary:  Generate HTML tag string with attributes
@ package:  view
@ frontend: false
@ backend:  true
@ requires: esc
@ tags:     tag html render view

function tag(string $tagName, ?string $inner = null, ...$args) => "<$tagName".loop(array_filter($args, fn($value) => !is_null($value)), fn($value, $key) => space.strtr($key, [us => dash]).($value === true ? void : '="'.esc($value).'"'), void).'>'.(is_null($inner) ? void : "$inner</$tagName>")
