@ version:  1.0
@ creator:  q-ai.nl
@ summary:  Unified AI facade with engine auto-detect
@ package:  ai
@ frontend: false
@ backend:  true
@ requires: HTTP @OpenAI? @Claude? @Gemini? @DeepSeek? @Grok?
@ tags:     ai facade llm streaming tools embeddings

prop model = 'gpt-5.4-mini'
const engines = ['claude' => 'Claude', 'gpt' => 'OpenAI', 'chatgpt' => 'OpenAI', 'o1' => 'OpenAI', 'o3' => 'OpenAI', 'o4' => 'OpenAI', 'deepseek' => 'DeepSeek', 'gemini' => 'Gemini', 'grok' => 'Grok']
static http(string $url, array $headers, bool $json = true, mixed $post = null):string => HTTP($url, $headers, $json, $post, timeout: 300)
method resolve(...$args):array {
	$via = $args['via'] ?? void
	unset($args['via'])
	$args['model'] ??= $this->model
	if ($via) $via = static::engines[strtolower($via)] ?? $via
	elseif (isset($args['model'])) $via = static::engines[strtolower(explode(dash, $args['model'])[0])] ?? void
	return [$via ?: 'OpenAI', $args]
}
method chat(...$args){
	[$engine, $args] = $this->resolve(...$args)
	return phlo($engine)->chat(...$args)
}
method stream(...$args):Generator {
	[$engine, $args] = $this->resolve(...$args)
	return phlo($engine)->stream(...$args)
}
method embedding(...$args){
	[$engine, $args] = $this->resolve(...$args)
	return phlo($engine)->embedding(...$args)
}
method vision(...$args){
	[$engine, $args] = $this->resolve(...$args)
	return phlo($engine)->vision(...$args)
}
method transcribe(...$args){
	[$engine, $args] = $this->resolve(...$args)
	return phlo($engine)->transcribe(...$args)
}
