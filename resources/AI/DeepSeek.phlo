@ version:  1.0
@ creator:  q-ai.nl
@ summary:  DeepSeek API (OpenAI-compatible, extends OpenAI)
@ extends:  OpenAI
@ package:  ai
@ frontend: false
@ backend:  true
@ requires: creds:DeepSeek @OpenAI @AI
@ tags:     ai deepseek chat embeddings

const model    = 'deepseek-chat'
const endpoint = 'https://api.deepseek.com/v1/'
const cred     = 'DeepSeek'
const label    = 'DeepSeek'

method embedding($input, $model = 'text-embedding-3-small') => %OpenAI->embedding($input, $model)
