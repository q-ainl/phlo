function phlo_sync(string $cb, ...$args) => last($cmd = '/usr/bin/php '.escapeshellarg(rtrim(www, slash).'/app.php').space.escapeshellarg($cb).loop($args, fn($a) => space.escapeshellarg((string)$a), void), exec($cmd, $r, $code), $out = implode(lf, $r), $j = json_decode($out, true), $code !== 0 ? error('Could not execute "'.esc($cb).'" via CLI') : (json_last_error() === JSON_ERROR_NONE ? $j : $out))
