@ version:     1.0
@ creator:     q-ai.nl
@ description: Google Gemini API

@ requires:    creds:Gemini

const model = 'gemini-2.0-flash'
const endpoint = 'https://generativelanguage.googleapis.com/v1beta/models/'

static context(...$args){
	$args['contents'] ??= []
	if (isset($args['system'])){
		$args['systemInstruction'] = arr(parts: [arr(text: $args['system'])])
		unset($args['system'])
	}
	if (isset($args['assistant']) && array_push($args['contents'], arr(role: 'model', parts: [arr(text: $args['assistant'])]))) unset($args['assistant'])
	if (isset($args['user']) && array_push($args['contents'], arr(role: 'user', parts: [arr(text: $args['user'])]))) unset($args['user'])
	return $args
}

method chat(...$args){
	$model = $args['model'] ?? static::model
	unset($args['model'])
	$args = static::context(...$args)
	$res = $this->request($model.':generateContent', POST: $args)
	$return = obj(answer: void, model: $model, finish: $res->candidates[0]->finishReason ?? void, tokens: ($res->usageMetadata->promptTokenCount ?? 0) + ($res->usageMetadata->candidatesTokenCount ?? 0), tokens_in: $res->usageMetadata->promptTokenCount ?? 0, tokens_out: $res->usageMetadata->candidatesTokenCount ?? 0)
	$tools = []
	foreach ($res->candidates[0]->content->parts ?? [] AS $part){
		if (isset($part->text)) $return->answer = $part->text
		elseif (isset($part->functionCall)) $tools[] = obj(name: $part->functionCall->name, args: (array)$part->functionCall->args)
	}
	if ($tools) $return->tools = $tools
	return $return
}

method stream(...$args){
	%app->streaming = true
	$model = $args['model'] ?? static::model
	unset($args['model'])
	$args = static::context(...$args)
	if (isset($args['cb'])){
		$cb = $args['cb']
		unset($args['cb'])
	}
	else {
		%req->cli || %res->header('Content-Type', 'text/event-stream')
		$cb = fn($text) => last(print($text), %req->cli || [@ob_flush(), flush()], $text)
	}
	$answer = void
	$buffer = void
	$url = static::endpoint.$model.':streamGenerateContent?alt=sse&key='.%creds->Gemini
	$curl = curl_init($url)
	curl_setopt($curl, CURLOPT_CUSTOMREQUEST, 'POST')
	curl_setopt($curl, CURLOPT_POSTFIELDS, $payload = json_encode($args))
	curl_setopt($curl, CURLOPT_HTTPHEADER, ['Content-Type: application/json', 'Content-Length: '.strlen($payload)])
	curl_setopt($curl, CURLOPT_WRITEFUNCTION, function($curl, $data) use ($cb, &$buffer, &$answer){
		$chunks = trim($buffer.$data)
		$buffer = void
		foreach (explode(lf.lf, $chunks) AS $chunk){
			if (!str_starts_with($chunk, 'data: ')){
				$buffer = $chunk
				continue
			}
			if ($obj = json_decode(substr($chunk, 6))){
				$text = $obj->candidates[0]->content->parts[0]->text ?? null
				if ($text !== null && $text !== void) $answer .= $cb($text, $obj)
			}
			else $buffer = $chunk
		}
		return strlen($data)
	})
	curl_exec($curl)
	return $answer
}

method request($path, ...$args){
	$res = json_decode(HTTP(static::endpoint.$path.'?key='.%creds->Gemini, ['Content-Type: application/json'], true, ...$args))
	if (isset($res->error)) error('Gemini Request error: '.$res->error->message)
	return $res
}
