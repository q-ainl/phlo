@ version:     2.0
@ creator:     q-ai.nl
@ description: Anthropic Claude API

@ requires:    creds:Claude

const model = 'claude-sonnet-4-5-20250929'

static context(...$args){
	$args['messages'] ??= []
	if (isset($args['system'])){
		$args['system'] = [arr(type: 'text', text: $args['system'])]
	}
	if (isset($args['assistant']) && array_push($args['messages'], arr(role: 'assistant', content: $args['assistant']))) unset($args['assistant'])
	if (isset($args['user']) && array_push($args['messages'], arr(role: 'user', content: $args['user']))) unset($args['user'])
	return $args
}

static tool($tool):array => arr (
	name: $tool->name,
	description: $tool->desc,
	input_schema: arr (
		type: 'object',
		properties: loop($tool->args, fn($data, $arg) => array_filter($data, fn($key) => in_array($key, ['type', 'enum', 'description']), ARRAY_FILTER_USE_KEY)),
		required: array_keys($tool->args),
	),
)

method embedding($input, $model = 'text-embedding-3-small') => %OpenAI->embedding($input, $model)

method vision($text, $image, $stream = false, ...$args) {
	$data = is_string($image) && str_starts_with($image, 'http') ? file_get_contents($image) : $image
	$messages = [arr(role: 'user', content: [arr(type: 'text', text: $text), arr(type: 'image', source: arr(type: 'base64', media_type: 'image/jpeg', data: base64_encode($data)))])]
	if ($stream) return $this->stream(...$args, messages: $messages)
	else return $this->chat(...$args, messages: $messages)
}

method chat(...$args){
	$args['model'] ??= static::model
	$args['max_tokens'] ??= 4096
	$args = static::context(...$args)
	$res = $this->request('messages', POST: $args)
	$return = obj(answer: void, model: $res->model, finish: $res->stop_reason, tokens: ($res->usage->input_tokens ?? 0) + ($res->usage->output_tokens ?? 0), tokens_in: $res->usage->input_tokens ?? 0, tokens_out: $res->usage->output_tokens ?? 0)
	$tools = []
	foreach ($res->content AS $block){
		if ($block->type === 'text') $return->answer = $block->text
		elseif ($block->type === 'tool_use') $tools[] = obj(name: $block->name, args: (array)$block->input)
	}
	if ($tools) $return->tools = $tools
	return $return
}

method stream(...$args){
	%app->streaming = true
	$args['model'] ??= static::model
	$args['max_tokens'] ??= 4096
	$args = static::context(...$args)
	$args['stream'] = true
	if (isset($args['cb'])){
		$cb = $args['cb']
		unset($args['cb'])
	}
	else {
		%req->cli || %res->header('Content-Type', 'text/event-stream')
		$cb = fn($text) => last(print($text), %req->cli || [@ob_flush(), flush()], $text)
	}
	$answer = void
	$buffer = void
	$curl = curl_init('https://api.anthropic.com/v1/messages')
	curl_setopt($curl, CURLOPT_CUSTOMREQUEST, 'POST')
	curl_setopt($curl, CURLOPT_POSTFIELDS, $payload = json_encode($args))
	curl_setopt($curl, CURLOPT_HTTPHEADER, ['anthropic-version: 2023-06-01', 'Content-Type: application/json', 'Content-Length: '.strlen($payload), 'x-api-key: '.%creds->Claude])
	curl_setopt($curl, CURLOPT_WRITEFUNCTION, function($curl, $data) use ($cb, &$buffer, &$answer){
		$chunks = trim($buffer.$data)
		$buffer = void
		foreach (explode(lf.lf, $chunks) AS $chunk){
			if (!str_starts_with($chunk, 'data: ')){
				$buffer = $chunk
				continue
			}
			if ($obj = json_decode(substr($chunk, 6))){
				if (($obj->type ?? null) === 'content_block_delta' && ($obj->delta->type ?? null) === 'text_delta'){
					$text = $obj->delta->text ?? null
					if ($text !== null && $text !== void) $answer .= $cb($text, $obj)
				}
			}
			else $buffer = $chunk
		}
		return strlen($data)
	})
	curl_exec($curl)
	return $answer
}

method request($uri, ...$args){
	$res = json_decode(HTTP("https://api.anthropic.com/v1/$uri", ['anthropic-version: 2023-06-01', 'Content-Type: application/json', 'x-api-key: '.%creds->Claude], true, ...$args))
	if (isset($res->error)) error('Claude Request error: '.$res->error->message)
	return $res
}
