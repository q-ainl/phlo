@ version:     1.0
@ creator:     q-ai.nl
@ description: Unified AI facade with auto-detect

const engines = ['claude' => 'Claude', 'gpt' => 'OpenAI', 'chatgpt' => 'OpenAI', 'o1' => 'OpenAI', 'o3' => 'OpenAI', 'o4' => 'OpenAI', 'deepseek' => 'DeepSeek', 'gemini' => 'Gemini']

static resolve(...$args):array {
	$via = $args['via'] ?? void
	unset($args['via'])
	if ($via) $via = static::engines[strtolower($via)] ?? $via
	elseif (isset($args['model'])) $via = static::engines[strtolower(explode('-', $args['model'])[0])] ?? void
	return [$via ?: 'OpenAI', $args]
}

method chat(...$args) {
	[$engine, $args] = static::resolve(...$args)
	return phlo($engine)->chat(...$args)
}

method stream(...$args) {
	[$engine, $args] = static::resolve(...$args)
	return phlo($engine)->stream(...$args)
}

method embedding(...$args) {
	[$engine, $args] = static::resolve(...$args)
	return phlo($engine)->embedding(...$args)
}
